Group #StatusEffectsContainer {
  Anchor: (Right: 30, Top: 120, Width: 80, Height: 800);

  @StatusEffectSlot #Effect1 {
    Visible: false;
    Anchor: (Top: 0);
  }
  @StatusEffectSlot #Effect2 {
    Visible: false;
    Anchor: (Top: 95);
  }
  @StatusEffectSlot #Effect3 {
    Visible: false;
