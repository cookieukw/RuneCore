
Group {
  LayoutMode: Bottom;
  Anchor: (Left: 48, Bottom: 148, Width: 358, Height: 64);

  Group {
    Group {
      Anchor: (Left: 0, Width: 310, Height: 26);
      Background: "ManaBackground.png";

      ProgressBar #ManaBar {
        Anchor: (Width: 302, Height: 20);
        BarTexturePath: "ManaBarFill.png";
      }
    }

    Group {
      Anchor: (Left: 0, Width: 34, Height: 34);
      Background: "ManaIcon.png";
    }
  }
}
